<!doctype html>
<html>
<head>
<meta http-equiv="x-ua-compatible" content="IE=edge">
<meta http-equiv="Content-Type" content="text/html; charset=utf-8">
<title>vSphere Support Bundle Analyzer</title>
<HTA:APPLICATION
  ID="vsHta"
  APPLICATIONNAME="vSphere Support Bundle Analyzer"
  BORDER="thick"
  CAPTION="yes"
  SCROLL="auto"
  SINGLEINSTANCE="no"
  SHOWINTASKBAR="yes"
  MAXIMIZEBUTTON="yes"
  MINIMIZEBUTTON="yes"
  INNERBORDER="no"
  CONTEXTMENU="yes"
  SELECTION="yes" />
<!--
  vSphere SUPPORT BUNDLE TRIAGE - member of the DFIR-Windows-Artifact-Finder wrapper family.
  Ingests an ESXi vm-support bundle OR a vCenter (VCSA) vc-support bundle (the nested .tgz/.tar
  that holds the hostname-rooted tree, or an already-extracted tree) and turns it into a
  file-inventory board + node-config summary. Auto-detects which of the two it is.

  GROUND TRUTH (two real sample bundles, 2026-07-09 - see SPEC.md):
   * ESXi bundle: outer .tgz -> inner <host>.tar -> tree rooted at the <host> folder. Inner logs
     are gzip (.gz). README "Command line:" starts with vm-support.cgi. Config in etc/vmware/,
     logs in scratch/log/ AND var/run/log/, command captures in commands/localcli_*.txt.
   * VCSA bundle: outer .tgz -> inner <host>.tgz that is REALLY A PLAIN TAR (magic ././@PaxHeader,
     despite the .tgz name) -> Photon-Linux tree. Inner logs are gzip (.gz) AND zstd (.zst); some
     command dumps are split into .FRAG-0000N. README "Command line:" starts with vc-support.
     Logs in var/log/vmware/<service>/ (vpxd, sso, vmdird ...) + var/log/audit + var/log/auth.log.
   * Detection: etc/vmware/esx.conf present => ESXi; var/log/vmware/vpxd/ present => VCSA; else the
     README Command line / bundle-name prefix (esx-* vs vc-*).
   * Bundles are 4-7 GB. The inventory board is built from the archive TABLE OF CONTENTS
     (bsdtar -tvf: "<mode> <own> <size> <YYYY-MM-DD> <HH:MM> <path>") so it paints WITHOUT full
     extraction; individual files are extracted on demand when Open file / Open folder is clicked.
   * Windows bsdtar (tar.exe) handles tar+gzip+PaxHeader but NOT zstd. zstd.exe is probed
     (tools\ -> PATH) and, if missing, offered as a prompted download from the official
     facebook/zstd GitHub release. .zst logs are still listed if zstd is absent.
   * This wrapper never runs vm-support/vc-support and never touches the source host.
-->
<style>
  html{margin:0;height:100%;background:#0d1117}
  body{margin:0;height:100%;background:#0d1117;color:#e6edf3;font-family:Segoe UI,Tahoma,sans-serif;font-size:16px}
  #content{zoom:0.9;width:111.111%;box-sizing:border-box}   /* zoom<1 shrinks a 100%-wide block to <100% of the viewport (blank gutter on the right); widen by 1/zoom so it renders back to full width */
  a{color:#58a6ff}
  .mono{font-family:Consolas,"Courier New",monospace}
  .muted{color:#8b949e}
  .err{color:#f85149}
  .ok{color:#3fb950}
  header{padding:8px 14px;background:#161b22;border-bottom:1px solid #30363d}
  header h1{display:inline-block;font-size:15px;margin:0;font-weight:600;vertical-align:middle}
  header h1 small{color:#8b949e;font-weight:400}
  .pill{display:inline-block;font-size:11px;color:#8b949e;border:1px solid #30363d;border-radius:20px;padding:2px 10px;margin-left:8px;vertical-align:middle}
  .pill.esxi{color:#7ee787;border-color:#2ea043}
  .pill.vcsa{color:#79c0ff;border-color:#1f6feb}
  .pill.ok{color:#7ee787;border-color:#2ea043}
  .pill.bad{color:#ff8b3d;border-color:#bd561d;cursor:pointer}
  #appver{font-weight:700}
  #apppill{cursor:default}
  .wrap{padding:12px 14px}
  .card{background:#161b22;border:1px solid #30363d;border-radius:8px;padding:12px;margin-bottom:12px}
  /* Heading ladder (was inverted: the pane title was 11px, SMALLER than the 12px headings inside it).
   pane title 14px  >  heading inside a pane 11px (.panel h4 / a section <h3> in the card body)  >
   table column header 10px (th). ".card > h3" = the card's OWN title (direct child); a nested <h3>
   rendered into a body div (e.g. "Top findings" in #secBody) is NOT a direct child and stays 11px.
   v1.16.0: section headings follow the UAC Analyzer convention - 11px UPPERCASE, letter-spaced,
   BRIGHT (#e6edf3) with any inline description staying muted/lowercase via its own span. */
.card h3{margin:0 0 8px;font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#e6edf3}
.card > h3{font-size:14px;margin:0 0 10px}
  label.fld{display:block;margin:6px 0 2px;font-size:11px;color:#8b949e}
  input.txt,select,textarea{background:#1c2330;border:1px solid #30363d;color:#e6edf3;border-radius:6px;padding:5px 8px;font-size:13px;font-family:Consolas,monospace}
  input.wide{width:62%}
  .btn{background:#1c2330;border:1px solid #30363d;color:#e6edf3;border-radius:6px;padding:6px 12px;font-size:13px;cursor:pointer;margin:2px}
  .btn:hover{border-color:#58a6ff}
  .btn.primary{background:#1f6feb;border-color:#1f6feb}
  .btn.green{background:#238636;border-color:#238636;color:#fff}
  .btn.green:hover{border-color:#3fb950}
  .btn.orange{background:#bd561d;border-color:#bd561d;color:#fff}
  .btn.orange:hover{border-color:#e3852a}
  .btn.purple{background:#6e40c9;border-color:#6e40c9;color:#fff}
  .btn.purple:hover{border-color:#8957e5}
  /* tab data-state colours (UAC Analyzer convention, v1.16.0): once a bundle is analysed the tab bar
     answers "where is there something to read" at a glance - selected stays blue (.on), light green =
     the tab has content, light orange = it parsed empty. Painted only after analysis. */
  .btn.hasdata{background:#cff3d9;border-color:#7bc99a;color:#0a1710}
  .btn.hasdata:hover{border-color:#2ea043}
  .btn.nodata{background:#ffe2c2;border-color:#e0a860;color:#1a1206}
  .btn.nodata:hover{border-color:#e3a03a}
  .maxwarn{display:inline-block;color:#e3b341;font-weight:600;cursor:help;border:1px solid #8a7a2a;background:#2a2410;border-radius:10px;padding:1px 8px;font-size:11px;margin-left:6px;vertical-align:middle}
  .btn.on{background:#1f6feb;border-color:#1f6feb;color:#fff}
  .btn[disabled]{opacity:.5;cursor:default}
  .row{white-space:nowrap}
  .stat{display:inline-block;background:#1c2330;border:1px solid #30363d;border-radius:8px;padding:6px 12px;margin:0 6px 6px 0;min-width:70px;vertical-align:top}
  .stat .n{font-size:17px;font-weight:700;display:block}
  .stat .l{font-size:10px;color:#8b949e;text-transform:uppercase;letter-spacing:.5px}
  .stat.flag{border-color:#8b3a3a}.stat.flag .n{color:#ff6b6b}
  .stat.warn{border-color:#8a7a2a}.stat.warn .n{color:#e3b341}
  .stat.ok2{border-color:#2ea043}.stat.ok2 .n{color:#7ee787}
  .cards3{width:100%}
  .col3{display:inline-block;width:32%;vertical-align:top;margin-right:1%}
  .kvgrid div{margin:2px 0;font-size:12px}
  .kvgrid .k{display:inline-block;width:150px;color:#8b949e;vertical-align:top}
  table{width:100%;border-collapse:collapse;font-size:12px}
  th,td{text-align:left;padding:4px 7px;border-bottom:1px solid #30363d;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  th{background:#1c2330;cursor:pointer;color:#c9d1d9;position:relative;z-index:3;box-shadow:0 1px 0 #30363d}
  th:hover{color:#58a6ff}
  .cgrip{position:absolute;top:0;right:0;width:10px;height:100%;cursor:col-resize;z-index:6}
  .cgrip:hover{background:#58a6ff;filter:alpha(opacity=55);opacity:.55}
  th:hover .cgrip{background:#30456a;filter:alpha(opacity=60);opacity:.6}
  td{max-width:560px}
  tr.absent td{opacity:.5}
  tr.key td.first{border-left:3px solid #1f6feb}
  .scroll{max-height:60vh;overflow:auto;border:1px solid #30363d;border-radius:8px;width:100%;box-sizing:border-box}
  .tag{display:inline-block;font-size:10px;padding:1px 6px;border-radius:10px;font-weight:600;margin-right:3px}
  .tag.cfg{background:#10233a;color:#79c0ff;border:1px solid #1f6feb}
  .tag.auth{background:#0f2a1a;color:#7ee787;border:1px solid #2ea043}
  .tag.audit{background:#2a2410;color:#e3b341;border:1px solid #8a7a2a}
  .tag.net{background:#241033;color:#c297ff;border:1px solid #6a3aa0}
  .tag.persist{background:#3a1416;color:#ff8b8b;border:1px solid #8b3a3a}
  .tag.cmd{background:#21262d;color:#8b949e;border:1px solid #30363d}
  .tag.danger{background:#3a1416;color:#ff6b6b;border:1px solid #b83030;font-weight:700}
  .tag.sus{background:#3a1416;color:#ff8b8b;border:1px solid #8b3a3a}
  /* tagCls() returns "ioc"/"info" but these had no rule and fell back to the unstyled base .tag -
     so IOC / CRITICAL / BREACH / UID0 (the strongest findings) rendered muted. ioc = brightest red. */
  .tag.ioc{background:#4a1418;color:#ff5c5c;border:1px solid #d13030;font-weight:700}
  .tag.info{background:#161b22;color:#8b949e;border:1px solid #30363d}
  .hl-ioc{color:#ff6b6b;font-weight:600}
  tr.hl-ioc td{color:#ff8b8b}
  .pgood{color:#3fb950;font-weight:600}.pmiss{color:#8b949e}.pkey{color:#e3b341;font-weight:700}
  .dl{font-family:Consolas,"Courier New",monospace;font-size:11px;max-height:340px;overflow:auto;background:#0d1117;border:1px solid #30363d;border-radius:6px;padding:6px;margin:4px 0;white-space:pre-wrap;word-break:break-word;width:100%;box-sizing:border-box}
  .lnk{cursor:pointer;color:#58a6ff}
  .lnk:hover{text-decoration:underline}
  .sep{display:inline-block;width:1px;height:18px;background:#30363d;margin:0 6px;vertical-align:middle}
  #log{white-space:pre-wrap;font-family:Consolas,monospace;font-size:11px;color:#8b949e;max-height:160px;overflow:auto;background:#0d1117;border:1px solid #30363d;border-radius:6px;padding:8px;display:none;margin-top:8px;width:100%;box-sizing:border-box}
  .hide{display:none}
  .modal{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.66);z-index:1000;overflow:auto}
  .modal .mcard{max-width:860px;margin:36px auto;background:#161b22;border:1px solid #30363d;border-radius:10px;padding:18px 22px}
  .modal h2{margin:0 0 6px;font-size:18px;font-weight:600}
  .modal h3{margin:12px 0 4px;font-size:12px;text-transform:uppercase;letter-spacing:.5px;color:#8b949e}
  .modal ul{margin:4px 0;padding-left:20px}.modal li{margin:3px 0;font-size:13px}
  .modal p{font-size:13px;margin:6px 0}
  .modal code{background:#0d1117;border:1px solid #30363d;border-radius:4px;padding:2px 6px;font-family:Consolas,monospace;font-size:12px}
  .modal .x{float:right;cursor:pointer;color:#8b949e;font-size:22px;line-height:1}.modal .x:hover{color:#e6edf3}
  .btn.sm{padding:2px 9px;font-size:11px;margin:0 2px}
  .ioctbl{width:100%;border-collapse:collapse;font-size:12px;margin-top:6px}
  .ioctbl th{text-align:left;color:#8b949e;font-weight:600;font-size:10px;text-transform:uppercase;letter-spacing:.5px;padding:3px 5px;border-bottom:1px solid #30363d}
  .ioctbl td{padding:2px 5px;vertical-align:middle}
  .ioctbl input.txt,.ioctbl select{width:100%;box-sizing:border-box;margin:0}
  .roadmap{font-size:11px;color:#8b949e;border:1px dashed #30363d;border-radius:6px;padding:6px 10px;margin-top:8px}
  .panel{border:1px solid #30363d;border-radius:8px;padding:10px 12px;background:#0f141b}
  .panel h4{margin:0 0 8px;font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:#e6edf3}
  .panel h4 .evf{font-size:11px;margin-right:6px;cursor:pointer;white-space:nowrap}
.sub{text-transform:none;letter-spacing:0;color:#8b949e;font-weight:400;font-size:11px}
  .ind{display:flex;align-items:flex-start;padding:4px 0;border-bottom:1px solid #1c222b;font-size:12px}
  .ind:last-child{border-bottom:none}
  .dot{width:9px;height:9px;border-radius:50%;margin:4px 8px 0 0;flex:0 0 auto;background:#3fb950}
  .dot.hit{background:#f85149}.dot.warn{background:#e3b341}.dot.na{background:#484f58}.dot.vfy{background:#f0883e}
  .ind .nm{width:230px;flex:0 0 auto;color:#e6edf3}
  .ind .dt{color:#8b949e}
  .ind .st{width:70px;flex:0 0 auto;font-weight:600}
  /* vfy = ORANGE, and deliberately NOT green: "verify" means the tool could not decide, which must never
     wear the same colour as "patched". It is also kept distinct from warn/amber ("review" = your build is
     below the vendor's fix, i.e. a finding) because an unknown and a finding are different things. */
  .st.hit{color:#ff6b6b}.st.clear{color:#3fb950}.st.na{color:#8b949e}.st.warn{color:#e3b341}.st.vfy{color:#f0883e}
  .advisory{font-size:11px;color:#e3b341;margin-bottom:6px}
</style>
</head>
<body>
<header>
  <h1>vSphere Support Bundle Analyzer</h1>
  <span class="pill ok" id="apppill">ESXi &amp; vCenter <span id="appver"></span></span>
  <span class="pill" id="verpill">tar: checking&hellip;</span>
  <span class="pill" id="zstdpill">zstd: &hellip;</span>
  <span class="pill" id="typepill">no bundle loaded</span>
  <span style="float:right">
    <button class="btn" id="instrBtn" title="Download &amp; open the latest Field Manual from GitHub">Instructions</button>
    <button class="btn" id="helpBtn" title="Help, about &amp; GitHub link">Help</button>
    <button class="btn primary hide" id="selfUpd" title="A newer version is available on GitHub">Update</button>
    <button class="btn" id="fdown" title="Smaller text">A&minus;</button>
    <button class="btn" id="fup" title="Larger text">A+</button>
  </span>
</header>

<div class="wrap" id="content">

  <!-- CONTROL PANEL -->
  <div class="card">
    <h3>Support bundle</h3>
    <div class="muted" id="exeline" style="font-size:11px;margin-bottom:6px"></div>
    <div id="netwarn" class="hide" style="background:#241c12;border:1px solid #8a7a2a;border-left:4px solid #e3b341;border-radius:6px;padding:8px 12px;margin-bottom:8px;font-size:12px;color:#e3b341">
      &#9888; This app appears to be on a <b>network / OneDrive / redirected</b> location. Windows blocks the fast UTF-8 reader there, so it falls back to slower ANSI IO (large logs read only partially; a long read may trigger a Windows &ldquo;stop running this script?&rdquo; prompt &mdash; click <b>No</b>). For full speed &amp; fidelity, copy this app <b>and the bundle</b> to a local drive (<code style="background:#0d1117;padding:1px 4px;border-radius:3px">C:\</code>) and re-run.
    </div>
    <label class="fld" title="Point at the nested archive that holds the tree (ESXi <host>.tar or VCSA <host>.tgz), the outer .tgz, or an already-extracted bundle folder. The tool auto-detects ESXi vs vCenter.">Bundle - nested archive (.tgz / .tar) or an already-extracted bundle folder</label>
    <input class="txt wide" id="inPath" value="">
    <input type="file" id="inPick" style="display:none">
    <button class="btn" id="browseBtn">Browse&hellip;</button>
    <button class="btn" id="folderBtn" title="Pick an already-extracted bundle folder instead of an archive.">Pick folder&hellip;</button>
    <label class="fld" title="Required. Guessed from the bundle name - overwrite if wrong. Names the output folder _Processed\&lt;host&gt;\vSphere next to this app.">Target hostname (required) - names the output folder _Processed\&lt;host&gt;\vSphere next to this app</label>
    <input class="txt" id="hostName" value="" style="width:300px" placeholder="e.g. esxi01 or vcsa01">
    <label class="fld">Output directory (TOC cache, extracted files, runinfo land here)</label>
    <input class="txt wide" id="outDir" value="">
    <button class="btn" id="openDirBtn">Open folder</button>
    <div style="margin-top:10px">
      <button class="btn orange" id="iocBtn" title="Create or edit the shared IOC list (IOC.csv &rarr; IOC.txt) that the IOC sweep matches against. Read by every wrapper in the family at launch.">Create IOC list</button>
      <span class="sep"></span>
      <button class="btn primary" id="procBtn" title="Read the bundle table of contents, detect the type, and build the file inventory + node-config summary.">Analyze bundle</button>
      <span class="sep"></span>
      <button class="btn" id="fleetBtn" title="Fleet mode: discover every ESXi/vCenter bundle under a folder (recursively) and triage them all into one roster. Point the Bundle field at a parent folder, or use Pick folder.">Triage fleet folder&hellip;</button>
      <label style="font-size:12px;margin-left:6px" title="Reuse a host's saved analysis from _Processed when the source bundle and tool version are unchanged - much faster on re-runs. Uncheck to force a full fresh re-analysis of every host."><input type="checkbox" id="fleetReuse" checked> reuse cached</label>
      <label style="font-size:12px;margin-left:6px" title="Also read the ROTATED logs (hostd.0.gz, auth.1.gz, ...) - weeks of extra logon/action history instead of just the live file. Slower (decompresses each rotation). The vobd audit log is always read in full (rotations are small and it is the host's audit trail). vpxd reads its newest 4 rotations by default; this raises it to 12."><input type="checkbox" id="deepRot"> incl. rotated logs</label>
      <label style="font-size:12px;margin-left:6px" title="Master network switch. When unticked the tool makes NO outbound connections: the GitHub update check, the live NVD CVE lookup, the zstd.exe download and the Field Manual fetch are all disabled. Analysis itself never needs the network. Persisted across sessions - untick it on an evidence-handling workstation."><input type="checkbox" id="netOn" checked> online (update check / NVD / zstd)</label>
      <span class="sep"></span>
      <button class="btn" id="logToggle">Show log</button>
      <span class="muted" id="status" style="margin-left:8px"></span>
    </div>
    <div id="log"></div>
  </div>

  <!-- FLEET ROSTER -->
  <div id="fleetCard" class="card hide">
    <div class="row" style="margin-bottom:8px">
      <b style="font-size:14px">Fleet roster</b>
      <span class="muted" id="fleetInfo" style="margin-left:10px;font-size:12px"></span>
      <span style="float:right">
        <input class="txt" id="fq" placeholder="filter hosts" style="width:200px">
        <button class="btn" id="corrBtn" title="Cross-host correlation: clusters, shared IPs/users/IOCs, coordinated indicators, vCenter&rarr;ESXi task chain">Correlation</button>
        <button class="btn green" id="fleetExport">Export roster &rarr; CSV</button>
        <button class="btn green" id="fleetReportBtn" title="One consolidated HTML report for the whole fleet.">Fleet report</button>
        <button class="btn" id="fleetClose" title="Return to single-bundle view">single-bundle view</button>
      </span>
    </div>
    <div class="scroll" id="fleetScroll" style="max-height:64vh"><table id="fleetTbl"></table></div>
    <div class="muted" style="font-size:11px;margin-top:6px">Sorted by risk (worst first). Grouped by cluster (vSAN sub-cluster UUID). Click a host to open its full single-bundle triage; use Correlation for cross-host analysis.</div>
  </div>

  <!-- CROSS-HOST CORRELATION -->
  <div id="corrCard" class="card hide">
    <div class="row" style="margin-bottom:8px">
      <b style="font-size:14px">Cross-host correlation</b>
      <span class="muted" id="corrInfo" style="margin-left:10px;font-size:12px"></span>
      <span style="float:right">
        <button class="btn green" id="corrExport" title="Export the merged cross-host flagged-event timeline to CSV">Export timeline &rarr; CSV</button>
        <button class="btn orange" id="corrBack">&#9664; Roster</button>
      </span>
    </div>
    <div id="corrBody"></div>
  </div>

  <!-- RESULTS -->
  <div id="results" class="hide">
    <div class="card">
      <div class="row" id="tabbar" style="margin-bottom:2px">
        <button class="btn on" id="tabOverview" data-tab="overview" title="Start here. Node summary (product / build / host / capture time), key-file coverage with any absent critical artifacts, and the advisory CVE-exposure card. The stat bubbles are clickable - they jump to the Logons / Actions / Timeline / IOC tabs. The intrusion &amp; ransomware indicators live on the Security tab.">Overview</button>
        <button class="btn" id="tabInv" data-tab="inv" title="The curated inventory board of forensically high-value files for this bundle type - present/absent, size, category and why each matters. A MISSING key log is itself a finding (blue left border = critical artifact). Open the file or reveal its folder; .gz/.zst are decompressed on demand.">Key Files</button>
        <button class="btn" id="tabSpec" data-tab="spec" title="What this node IS, parsed from its config (not an incident view). Identity, product/build, networking (VMkernel adapters, physical NICs, gateway/DNS/NTP), datastores, vSAN &amp; disk layout, and - on vCenter - the managed ESXi inventory and SSO identity sources. Exports a standalone specification HTML.">Specification</button>
        <button class="btn" id="tabSec" data-tab="sec" title="Opens with the intrusion &amp; ransomware indicator panel (derived from the parsed Logons/Actions + node config - SSH/shell use, external source IPs, host-encryption or recovery-key access, mass power-off, firewall disabled, payloads in /tmp, bulk VMDK/VMX ops, ransom-note scan). Below it, the graded security posture: installed VIBs (unsigned / CommunitySupported / unrecognized vendor / added after the base image), VIB acceptance level, host encryption mode, Secure Boot / TPM / execInstalledOnly, MOB, account lockout and password policy, shell/SSH idle timeout, DCUI access list, plus the advisory known-CVE exposure.">Security</button>
        <button class="btn" id="tabNet" data-tab="net" title="Socket snapshot at capture time (ESXi: localcli network ip connection list; vCenter: netstat -anp) - listeners, which are network-facing vs loopback-only, established external connections, and suspicious processes holding sockets. Also the web/proxy request summary by source IP.">Network</button>
        <button class="btn" id="tabVms" data-tab="vms" title="The hosted VM inventory. ESXi: parsed from each registered .vmx, and VMs whose .vmx is missing or ransom-renamed are still listed and tagged 'possibly encrypted'. vCenter: reconstructed from vpxd + DRS dumps + the vSAN-health baseline (a vc-support bundle has no .vmx). Includes the vSAN GUID Path for recovery. Click a VM (ESXi) for its activity timeline.">VMs</button>
        <button class="btn" id="tabUsers" data-tab="users" title="Every account this bundle gives evidence for, from CONFIG (etc/passwd / etc/group / SSH authorized_keys where captured - vm-support usually omits passwd, so on ESXi the GROUP file is the created-account tell) joined with OBSERVED ACTIVITY (logons OK/FAIL, external source IPs, sessions, actions, SSO identity events). Flags UID-0 clones, non-stock local accounts and service accounts with shells.">Users</button>
        <button class="btn" id="tabLogon" data-tab="logon" title="Who authenticated, from where. ESXi: shell.log, auth.log (SSH/DCUI/PAM) and hostd SOAP logins. vCenter: SSO websso.log (the authoritative login source), OS auth.log/sudo, and human SAML logins from vpxd. Shows user, source IP, success/failure - scored for external/public IPs, failures, and privileged accounts.">Logons</button>
        <button class="btn" id="tabAct" data-tab="act" title="What was DONE, and by whom. ESXi: shell command history and hostd tasks. vCenter: meaningful vpxd tasks (*_Task, permission/role changes) attributed to the nearest preceding human login. Scored for suspicious commands - SSH enable, host-encryption change, mass power-off, firewall disable, payloads in /tmp, bulk VMDK ops.">Actions</button>
        <button class="btn" id="tabTime" data-tab="time" title="Logons and Actions merged into one time-ordered view - the sequence that turns isolated events into a story. Filter by score and by the case window (Set case window /from /to). Exports a Timeline-Explorer-friendly CSV.">Timeline</button>
        <button class="btn" id="tabPersist" data-tab="persist" title="Persistence &amp; tampering checks against what the bundle actually captured (anything not collected is marked 'not captured' rather than passed). DCUI banner ransom-note scan, rc.local.d boot persistence, remote syslog forwarding changes, VIB acceptance, SSH authorized_keys, cron/systemd units, ld.so.preload, and key-log integrity (empty / truncated / time gaps).">Persistence</button>
        <button class="btn" id="tabIoc" data-tab="ioc" title="Hits for your IOC list (shared toolkit IOC.txt / IOC.csv - use 'Create IOC list' to edit) swept across the key logs present in this bundle, not the whole tree. IPs, users, hashes, filenames, keywords. Any hit scores +3 wherever it appears.">IOC hits</button>
        <button class="btn orange hide" id="backRosterBtn" style="float:right" title="Return to the fleet roster (kept in memory - no re-scan)">&#9664; Fleet roster</button>
      </div>
      <div class="roadmap">Logons / Actions / Timeline / Persistence / IOC parse the key logs &amp; config automatically after Analyze (Re-run on Overview). Overview shows the ransomware-indicator &amp; CVE-exposure panels; Generate Report writes every tab into one self-contained HTML. Case window (/from /to) filters Timeline &amp; Logons, never scores. Next: fleet / multi-host mode.</div>
    </div>

    <!-- OVERVIEW -->
    <div class="card" id="ovCard">
      <h3>Node overview</h3>
      <div class="cards3">
        <div class="col3" style="width:49%">
          <h3>Node configuration</h3>
          <div class="kvgrid" id="ovMeta"></div>
        </div>
        <div class="col3" style="width:49%">
          <div id="ovMissing" style="margin-top:8px"></div>
        </div>
      </div>
      <div style="margin-top:12px;border-top:1px solid #30363d;padding-top:10px">
        <button class="btn" id="anBtn" title="Re-parse the key logs (auth/shell/hostd/websso/vpxd) into Logons, Actions, Timeline and re-sweep IOCs. Runs automatically after Analyze; click to re-run.">Re-run log analysis</button>
        <button class="btn green" id="reportBtn" title="Generate a self-contained HTML report - every tab in one document (node config, maintenance, key files, specification, VMs, network, indicators, CVEs, security posture, persistence, logons, sessions, actions, timeline, IOC hits) - and open it.">Generate Report</button>
        <span class="muted" id="anStatus" style="margin-left:8px;font-size:12px">Runs automatically after Analyze.</span>
        <div id="anStats" style="margin-top:8px"></div>
      </div>
      <div id="ovMaintWrap" class="hide" style="margin-top:12px"><div id="ovMaint"></div></div>
      <div id="ovCve" style="margin-top:12px"></div>
    </div>

    <!-- VMs -->
    <div class="card hide" id="vmsCard">
      <div class="row" style="margin-bottom:8px">
        <b style="font-size:14px">Hosted VMs</b>
        <span class="muted" id="vmsInfo" style="margin-left:10px;font-size:12px"></span>
        <span style="float:right">
          <label style="margin-right:8px;font-size:12px;cursor:pointer" title="Simplified view (default): show only VMs with an identified host, and just the VM / Host / Status columns. Untick for the full inventory incl. VMs with no resolved host (powered off, template, or baseline-only) and all detail columns."><input type="checkbox" id="vmSimple" checked> Simplified</label>
          <select id="vmOs" class="txt" style="max-width:200px" title="Filter by Guest OS"></select>
          <input class="txt" id="vmq" placeholder="filter VMs" style="width:200px">
          <button class="btn green" id="vmsExport">Export VMs &rarr; CSV</button>
        </span>
      </div>
      <div class="scroll" id="vmsScroll" style="max-height:56vh"><table id="vmsTbl"></table></div>

      <!-- Virtual Machine Events -->
      <div id="vmEvWrap" class="hide" style="margin-top:14px;border-top:1px solid #30363d;padding-top:10px">
        <div class="row" style="margin-bottom:6px">
          <b style="font-size:14px">Virtual Machine events</b>
          <span class="muted" id="vmEvInfo" style="margin-left:10px;font-size:12px"></span>
          <span style="float:right">
            <span class="muted" style="font-size:11px;margin-right:4px" title="Show only these kinds of event. All are on by default - untick to narrow.">Type:</span>
            <label class="evf" title="VM created, cloned, or registered into inventory."><input type="checkbox" class="vmEvK" value="create" checked> create</label>
            <label class="evf" title="VM destroyed (deleted from disk) or unregistered from inventory. The ransomware-relevant one."><input type="checkbox" class="vmEvK" value="delete" checked> delete</label>
            <label class="evf" title="VM reconfigured (hardware/settings), renamed, or its template state changed."><input type="checkbox" class="vmEvK" value="modify" checked> modify</label>
            <label class="evf" title="VM powered on."><input type="checkbox" class="vmEvK" value="start" checked> start</label>
            <label class="evf" title="VM powered off, suspended, or a guest shutdown/standby was requested. A burst of these before an encryption window is the classic tell."><input type="checkbox" class="vmEvK" value="stop" checked> stop</label>
            <label class="evf" title="VM reset (hard reboot) or a guest reboot was requested."><input type="checkbox" class="vmEvK" value="reboot" checked> reboot</label>
            <label class="evf" title="Snapshot created, removed, consolidated, or reverted. Snapshot removal destroys restore points - review against any encryption window."><input type="checkbox" class="vmEvK" value="snapshot" checked> snapshot</label>
            <label class="evf" title="VM migrated / relocated (vMotion or Storage vMotion), including DRS-initiated moves."><input type="checkbox" class="vmEvK" value="migrate" checked> migrate</label>
            <input class="txt" id="vmEvQ" placeholder="filter events" style="width:150px;margin-left:6px">
            <button class="btn green" id="vmEvExport" title="Export the VM events exactly as filtered here to CSV.">Export &rarr; CSV</button>
          </span>
        </div>
        <div class="scroll" id="vmEvScroll" style="max-height:40vh"><table id="vmEvTbl"></table></div>
        <div class="muted" style="font-size:11px;margin-top:6px" id="vmEvNote"></div>
      </div>
      <div class="muted" style="font-size:11px;margin-top:6px"><b>Simplified</b> (on by default) shows only VMs with an identified host, with just the VM / Host / Status columns - untick it for the full inventory (VMs with no resolved host: powered off, templates, or baseline-only) and every evidence column. Parsed from the registered VMs' .vmx files on an ESXi bundle; reconstructed from vpxd / DRS dumps / the vSAN-health baseline on a vCenter bundle. <b>Click a VM</b> to open its <b>activity timeline</b> (power / snapshot / migration / guest-op events from vmware.log, with the opID that joins the vCenter task chain) - snapshot delete/consolidate before an encryption window is the ransomware tell; then <i>view .vmx config</i> for disk paths. Guest IP is not captured in ESXi bundles. See Specification for the node's vSAN &amp; disk layout.</div>
    </div>

    <!-- SPECIFICATION -->
    <div class="card hide" id="specCard">
      <h3>Specification <span class="muted" style="text-transform:none;font-weight:400">- node configuration parsed from the bundle</span>
        <button class="btn green" id="specExport" style="float:right" title="Export this node's specification (config, networking, storage/vSAN, VMs) to a self-contained HTML.">Export &rarr; HTML</button>
      </h3>
      <div id="specBody"></div>
    </div>

    <!-- NETWORK: listeners / connections / suspicious processes -->
    <div class="card hide" id="netCard">
      <h3>Network &amp; processes <span class="muted" style="text-transform:none;font-weight:400" id="netScore"></span></h3>
      <div class="muted" style="font-size:11px;margin-bottom:8px">Point-in-time snapshot from the bundle's socket + process captures - listening services, established connections to external (public) IPs, and a scan for attacker-tool / reverse-shell process patterns. A network-facing listener from an unexpected process, or a session to a public IP, is the review target.</div>
      <div id="netBody"></div>
    </div>

    <!-- SECURITY POSTURE -->
    <!-- intrusion / ransomware indicators - lives on the Security tab, above Security posture -->
    <div class="card hide" id="secIndicCard">
      <div id="ovIndic"></div>
    </div>

    <div class="card hide" id="secCard">
      <h3>Security posture <span class="muted" style="text-transform:none;font-weight:400" id="secScore"></span>
        <button class="btn green" id="secExport" style="float:right" title="Export a security-focused report (posture score, patch state/CVEs, intrusion indicators, control matrix, VIB integrity, persistence) to a self-contained HTML.">Export &rarr; HTML</button>
      </h3>
      <div class="muted" style="font-size:11px;margin-bottom:8px">Graded review of patch state and recommended security controls, checked against the bundle's config captures AND the parsed log evidence. Support bundles are targeted - a control whose source is not captured is graded <b>n/a</b>, never assumed compliant. Verdicts are advisory - verify before reporting.</div>
      <div id="secBody"></div>
    </div>

    <!-- GENERIC ANALYSIS TABLE (logon / act / time / ioc) -->
    <div class="card hide" id="tblCard">
      <div class="row" style="margin-bottom:8px">
        <input class="txt" id="tq" placeholder="filter this view" style="width:280px">
        <span id="dateWrap" class="hide"><span class="sep"></span>
          <input class="txt mono" id="dfrom" placeholder="from YYYY-MM-DD" style="width:130px" title="Case window (UTC) - filters Timeline &amp; Logons only, never scores">
          <span class="muted">&rarr;</span>
          <input class="txt mono" id="dto" placeholder="to YYYY-MM-DD" style="width:130px"></span>
        <span id="sessWrap" class="hide"><span class="sep"></span>
          <label style="font-size:12px" title="Pair Login/Logout into one row per API session. vCenter: vpxd SessionManager calls keyed by session ID (user from the SAML token; source IP time-joined from the envoy access log when unambiguous). ESXi: hostd session events (logout carries API-call count and client agent). An API session is ANY client session (vSphere Client, managed hosts, solutions) - not only humans."><input type="checkbox" id="sessView"> Login sessions (paired)</label>
          <span id="sessOpts" class="hide"> &middot;
            <label style="font-size:12px" title="Hide sessions whose source IP is loopback (127.0.0.1 / ::1) - the appliance's own internal services, not remote clients. On by default; a session whose IP could not be resolved is kept."><input type="checkbox" id="sessLoop" checked> hide loopback</label> &middot;
            <label style="font-size:12px" title="Hide brief sessions below the threshold - the short automated API sessions (often 0s, a few invocations). Sessions with no logout (unknown duration) are always kept."><input type="checkbox" id="sessMinOn"> hide brief &lt;</label> <input class="txt mono" id="sessMinSec" value="5" style="width:40px" title="Minimum session duration, seconds"> s &middot;
            <label style="font-size:12px" title="Hide unpaired rows - sessions missing a login or logout in the captured window (blank duration: still active at capture, pre-window, or a failed login). The brief filter deliberately keeps these; tick this to drop them too."><input type="checkbox" id="sessNoUnp"> hide unpaired</label></span></span>
        <span id="actFilt" class="hide"><span class="sep"></span>
          <span style="font-size:12px">actor <select id="actActor" class="txt" style="max-width:160px" title="Filter Actions by actor"></select> &middot; kind <select id="actKind" class="txt" style="max-width:170px" title="Filter Actions by kind"></select></span></span>
        <span id="usersFilt" class="hide"><span class="sep"></span>
          <span style="font-size:12px">user <select id="userSel" class="txt" style="max-width:190px" title="Filter by BASE identity (the part before @). Selecting 'administrator' shows every variant that base was attempted under - all domains AND all typo'd principal strings from failed logons, which is exactly how a guessing/typo cluster is reviewed as one group."></select></span></span>
        <span id="timeFilt" class="hide"><span class="sep"></span>
          <span style="font-size:12px">kind <select id="timeKind" class="txt" style="max-width:180px" title="Filter Timeline by kind"></select></span></span>
        <span class="sep"></span>
        <span style="font-size:12px" id="scoreFilt" title="Multiselect: show rows in the ticked score bands">Score:
          <label style="color:#ff6b6b"><input type="checkbox" id="scf5" checked>&ge;5</label>
          <label style="color:#f0883e"><input type="checkbox" id="scf3" checked>3-4</label>
          <label style="color:#7ee787"><input type="checkbox" id="scf1" checked>1-2</label>
          <label style="color:#8b949e"><input type="checkbox" id="scf0" checked>0</label>
        </span>
        <span class="sep"></span>
        <button class="btn" id="tclear">clear</button>
        <button class="btn purple" id="texport">Export view &rarr; CSV</button>
        <button class="btn purple" id="tcopy">Copy to Clipboard</button>
        <span class="muted" id="tcount" style="margin-left:8px"></span>
      </div>
      <div class="scroll" id="tblScroll"><table id="tbl"></table></div>
      <div class="muted" style="font-size:11px;margin-top:6px">All times UTC. Row tint = score (red &ge;5, amber 3-4); red left-border = IOC hit. Max <span id="anMaxLbl"></span> rows shown; export writes the full filtered set.</div>
    </div>

    <!-- KEY FILES INVENTORY -->
    <div class="card hide" id="invCard">
      <div class="row" style="margin-bottom:8px">
        <input class="txt" id="q" placeholder="filter (file, description, category)" style="width:300px">
        <span class="sep"></span>
        <select id="catSel" title="Filter by category">
          <option value="">all categories</option>
          <option value="Config">Config</option>
          <option value="Auth/Logons">Auth/Logons</option>
          <option value="Actions/Audit">Actions/Audit</option>
          <option value="Network">Network</option>
          <option value="Persistence">Persistence</option>
          <option value="Command-capture">Command-capture</option>
        </select>
        <label style="font-size:12px;margin-left:8px" title="Show only files present in this bundle."><input type="checkbox" id="presOnly"> present only</label>
        <span class="sep"></span>
        <button class="btn" id="clearBtn">clear</button>
        <button class="btn green" id="exportBtn">Export inventory &rarr; CSV</button>
        <span class="muted" id="count" style="margin-left:8px"></span>
      </div>
      <div class="scroll" id="invScroll"><table id="invTbl"></table></div>
      <div class="muted" style="font-size:11px;margin-top:6px">Blue left-border = high-value ("key") artifact. Sizes come from the archive index; Open file / Open folder extract just that item on demand (gzip auto-decompressed; zstd needs zstd.exe). Absent key files are themselves a finding.</div>
    </div>

    <!-- FILE PREVIEW -->
    <div class="card hide" id="detailCard">
      <h3>Preview <span class="lnk" id="detClose" style="float:right">close &times;</span></h3>
      <div id="detBody"></div>
    </div>
  </div>

</div>

<!-- HELP MODAL -->
<div class="modal hide" id="helpModal">
  <div class="mcard">
    <span class="x" id="helpX">&times;</span>
    <h2>vSphere Support Bundle Analyzer <span class="muted" id="helpVer" style="font-size:13px"></span></h2>
    <p>DFIR triage of an <b>ESXi</b> <code>vm-support</code> or <b>vCenter (VCSA)</b> <code>vc-support</code> bundle — auto-detected. Point at the nested archive that holds the tree (ESXi <code>&lt;host&gt;.tar</code> / VCSA <code>&lt;host&gt;.tgz</code>), the outer <code>.tgz</code>, or an extracted folder; or point at a <b>folder of bundles</b> for fleet mode. Log analysis runs automatically after Analyze. All times shown are UTC.</p>
    <h3>Tabs</h3>
    <ul>
      <li><b>Overview</b> — node summary, key-file coverage, the ransomware/intrusion <b>indicator</b> panel and the <b>CVE-exposure</b> panel (links to NVD/VMSA). The stat bubbles are clickable.</li>
      <li><b>Specification</b> — identity, networking, datastores + <b>vSAN &amp; disk layout</b>, security posture; for vCenter the SSO/AD identity sources and managed hosts. Exports a node-spec HTML.</li>
      <li><b>VMs</b> (ESXi) — per-VM inventory (OS, vCPU, vRAM, vDisks, vSAN, running); click a VM to preview its <code>.vmx</code>. Guest IP is enriched from a vCenter in the fleet.</li>
      <li><b>Key Files</b> — curated high-value artifacts. <b>Logons / Actions / Timeline</b> — scored, colour-coded, filterable events. <b>Persistence</b> — file-inspection findings. <b>IOC hits</b> — sweeps an <code>IOC.txt</code> placed next to the app.</li>
    </ul>
    <h3>Fleet mode</h3>
    <p>Point at a parent folder and click <b>Triage fleet folder…</b> for a risk roster, vSAN <b>cluster</b> grouping, and <b>cross-host correlation</b> (shared IPs/users/IOCs, coordinated indicators, and the <b>vCenter&rarr;ESXi task chain</b>).</p>
    <h3>Requirements &amp; tips</h3>
    <p>Windows 10/11 (ships bsdtar). <b>Run from a local drive</b> (<code>C:\</code>) — running from a network / OneDrive / redirected folder makes Windows fall back to a slower ANSI file reader. <code>.zst</code> vCenter logs need <code>zstd.exe</code> (the tool offers to fetch it). The version pill turns <span style="color:#7ee787">green</span> when current and <span style="color:#ff8b3d">orange</span> with an update link when a newer release exists; <b>Instructions</b> opens the latest Field Manual.</p>
    <p class="mono" style="font-size:12px"><span class="lnk" id="ghLink">github.com/bpmorris22/vSphere-SupportBundle-Analyzer</span> &middot; MIT</p>
  </div>
</div>

<!-- IOC LIST EDITOR MODAL -->
<div id="iocModal" class="modal hide" onclick="if((event.srcElement||{}).id==='iocModal')closeIocEditor()">
  <div class="mcard" style="max-width:920px">
    <span class="x" onclick="closeIocEditor()" title="Close">&times;</span>
    <h2>IOC list editor <span class="muted" style="font-size:13px;font-weight:400">- IOC.csv &rarr; IOC.txt</span></h2>
    <p><b>IOC.csv</b> (Value / Type / Note / Case) is the editable source of truth. On <b>Save</b> it is flattened to <b>IOC.txt</b> - one term per line - which this tool (and every wrapper in the family) auto-loads at launch and sweeps the key logs for. Type / Note / Case are analyst-side metadata; only <b>Value</b> is matched.</p>
    <div id="iocTblWrap"></div>
    <div style="margin-top:10px">
      <span class="btn sm" onclick="iocAddRow()">+ Add row</span>
      <span class="lnk" style="margin-left:14px" onclick="iocOpenNotepad()" title="Open the generated IOC.txt in Notepad (raw view - regenerated on the next Save)">Open IOC.txt in Notepad</span>
    </div>
    <div style="margin-top:14px">
      <span class="btn primary" onclick="iocSave()">Save</span>
      <span class="btn" onclick="closeIocEditor()">Cancel</span>
      <span class="muted" id="iocStatus" style="margin-left:12px;font-size:12px"></span>
    </div>
  </div>
</div>

<script language="JScript">
"use strict";

var APP_VERSION = "1.16.0";
var APP_NAME    = "vSphere";
var SELF_HTA    = "vSphere-SupportBundle-Analyzer.hta";
var SELF_REPO   = "bpmorris22/vSphere-SupportBundle-Analyzer";
var GITHUB      = "https://github.com/"+SELF_REPO;

var TAR="", TAR_VER="", ZSTD="";
var MODE="";                 // "toc" (archive) | "tree" (extracted folder)
var ARCHIVE="";              // archive path (toc mode)
var ROOT="";                 // bundle root folder (tree mode) - includes the <host> prefix
var PREFIX="";               // leading path component inside the archive (toc mode)
var BTYPE="";                // "esxi" | "vcsa" | ""
var TOC=[];                  // toc mode: [{rel,size}]
var TOCMAP={};               // rel -> size (files only)
var INVENTORY=[];            // [{cat,name,desc,rels,prefix,key,present,size,count,rel}]
var NODE={};                 // node-config kv
var LASTOUTDIR="", EXDIR="", NODEDIR="";
var TAB="overview", QUERY="", CATF="", PRESONLY=false, BUSY=false, qTimer=null, inTimer=null;
var SORT={ inv:{k:0,d:1}, logon:{k:0,d:-1}, act:{k:0,d:-1}, time:{k:1,d:-1}, ioc:{k:0,d:1}, sess:{k:0,d:-1}, users:{k:0,d:-1} };
var SESSIONS=[];        // paired login sessions (Logons tab "Login sessions" view)
var SESS_VIEW=false;    // Logons tab: false=raw login events, true=paired sessions
var SESS_HIDELOOP=true; // sessions view: hide loopback-source (internal-service) sessions - ON by default
var SESS_MINON=false;   // sessions view: hide brief sessions (< SESS_MINSEC)
var SESS_MINSEC=5;      // brief-session threshold, seconds
var SESS_NOUNP=false;   // sessions view: hide unpaired rows (no login or no logout in window = blank duration)
var LISTEN_HIDELOOP=true; // Network tab: hide loopback-only listeners - ON by default
var ACT_ACTOR="", ACT_KIND="";  // Actions tab: actor + kind dropdown filters
var USER_SEL="";                // Users tab: base-identity dropdown filter
var TIME_KIND="";               // Timeline tab: kind dropdown filter
var VM_OS="";                   // Hosted VMs tab: Guest-OS dropdown filter
var VM_SIMPLE=true;             // Hosted VMs tab: Simplified view (default ON) - only VMs with an identified host, VM/Host/Status columns only
/* analysis datasets (v0.2) */
var LOGON=[], ACTIONS=[], TIMELINE=[], IOCHITS=[], IOCS=[];
var ANALYZED=false, TQUERY="", FLAGONLY=false, DFROM=0, DTO=0, ANMAXROWS=8000;
var SCOREF={c5:true,c3:true,c1:true,c0:true};   // multiselect score-bucket filter
function scoreBucket(s){ return s>=5?"c5":(s>=3?"c3":(s>=1?"c1":"c0")); }
function scorePass(s){ return !!SCOREF[scoreBucket(s)]; }
var LOGCAP=48*1024*1024;   // per-log read cap (bytes) - guards against 100MB+ logs
/* run-generation counter (v1.15.0). Every analyze()/fleet run increments it; every async callback
   (tar polling, NVD replies, deferred runAnalysis timers) captures the value at start and bails if
   it no longer matches - so a late tar index or a slow NVD reply from run A can never mutate run B's
   state. Cheaper and just as airtight as an immutable context object in a codebase this global. */
var RUNID=0;
var NET_ON=true;           // master egress switch (update check / NVD / zstd / manual fetch) - persisted
var VPXD_LINES=null;       // per-run cache of the merged chronological vpxd line set (vcsa)
var VPXD_SRCNOTE="";       // which vpxd files fed VPXD_LINES (for provenance/log)
/* per-run cache of parsed log line-arrays (v1.15.1). The ESXi passes read the same files repeatedly -
   hostd.log three times (logons / sessions / VM events), every vobd rotation twice (maintenance +
   audit) - and each re-read of a CAPPED log pushed a duplicate LOG_TRUNC entry. Consumers never
   mutate the arrays (verified), so one read serves all passes. Budgeted, cleared per run/host. */
var LOGCACHE={}, LOGCACHE_BYTES=0, LOGCACHE_MAX=160*1024*1024;
function logCacheClear(){ LOGCACHE={}; LOGCACHE_BYTES=0; }
var TOC_BAD=0, TOC_BADSAMPLE=[], TOC_CLASH=0, TOC_CLASHSAMPLE=[];   // malicious-member rejections (per index)
var SELF_SHA=null;         // lazy SHA-256 of this .hta (certutil), for run provenance
var WRAPD=0;               // outer-wrapper unwrap depth this run (max 1 unwrap: outer -> nested bundle)

/* ---------- tiny helpers (family) ---------- */
function $(id){ return document.getElementById(id); }
function esc(s){ if(s==null) return ""; s=String(s);
  return s.replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;"); }
function nf(n){ n=String(n); var r="",c=0; for(var k=n.length-1;k>=0;k--){ r=n.charAt(k)+r; c++; if(c%3===0&&k>0) r=","+r; } return r; }
function setStatus(msg,cls){ var el=$("status"); el.innerHTML=esc(msg); el.className=cls||"muted"; }
function appendLog(t){ var el=$("log"); if(el.getAttribute("data-ph")==="1"){ el.innerHTML=""; el.setAttribute("data-ph","0"); }
  el.style.display="block"; $("logToggle").innerHTML="Hide log"; el.innerHTML+=esc(t)+"\n"; el.scrollTop=el.scrollHeight; }
function trimStr(s){ return String(s).replace(/^\s+|\s+$/g,""); }
function baseName(p){ if(!p) return ""; p=String(p); var i=Math.max(p.lastIndexOf("\\"),p.lastIndexOf("/")); return i>=0?p.substring(i+1):p; }
function showEl(id,vis){ var e=$(id); if(!e) return; var c=e.className.replace(/\s*\bhide\b/g,""); e.className = vis ? c : (c+" hide"); }
function trunc(s,n){ s=String(s); return s.length>n?(s.substring(0,n)+"…"):s; }
function lc(s){ return String(s==null?"":s).toLowerCase(); }
/* build a Windows on-disk relative path. bsdtar rewrites NTFS-illegal chars (esp. the ':' in vSAN
   datastore paths like vsan:523b...) to '_' on extraction, so we must do the same to locate the
   extracted file. Extraction MEMBERS passed to bsdtar keep the original ':' (the archive name). */
function winRel(rel){ return String(rel).replace(/\//g,"\\").replace(/[:*?"<>|]/g,"_"); }
function fmtSize(n){ if(!n) return (n===0?"0 B":"-"); var u=["B","KB","MB","GB","TB"], i=0; while(n>=1024&&i<u.length-1){n/=1024;i++;} return n.toFixed(i?1:0)+" "+u[i]; }

/* ---------- file IO via ActiveX (UTF-8 safe, network-zone fallback) - family ---------- */
var FILE_IO="adodb";
function zoneNote(){ appendLog("NOTE: a network / OneDrive / redirected location was detected - Windows zone policy blocks the fast UTF-8 reader, so the app fell back to slower ANSI file IO (large logs are read only partially, and long reads can trigger a 'stop running this script?' prompt - just click No). Triage still works. For full speed & fidelity, copy the app AND the bundle to a LOCAL drive (C:\\) and re-run.");
  try{ showEl("netwarn",true); }catch(e){} }
function readUtf8(path){
  if(FILE_IO==="adodb"){
    try{ var st=new ActiveXObject("ADODB.Stream"); st.Type=2; st.Charset="utf-8"; st.Open(); st.LoadFromFile(path);
      var parts=[]; while(!st.EOS){ parts.push(st.ReadText(65536)); } st.Close(); return parts.join(""); }
    catch(e){ if(!/safety settings|data source/i.test(e.message||"")) throw e; FILE_IO="fso"; zoneNote(); }
  }
  var fso=new ActiveXObject("Scripting.FileSystemObject");
  var f=fso.OpenTextFile(path,1,false,0), out=f.ReadAll(); f.Close();
  if(out.length>=3 && out.charCodeAt(0)===239 && out.charCodeAt(1)===187 && out.charCodeAt(2)===191) out=out.substring(3);
  return out;
}
function writeUtf8(path,text){
  if(FILE_IO==="adodb"){
    try{ var st=new ActiveXObject("ADODB.Stream"); st.Type=2; st.Charset="utf-8"; st.Open(); st.WriteText(text); st.SaveToFile(path,2); st.Close(); return; }
    catch(e){ if(!/safety settings|data source/i.test(e.message||"")) throw e; FILE_IO="fso"; zoneNote(); }
  }
  var fso=new ActiveXObject("Scripting.FileSystemObject");
  var f=fso.CreateTextFile(path,true,false); f.Write(text); f.Close();
}
function uid(){ return new Date().getTime()+""+Math.floor(Math.random()*100000); }
function batEsc(s){ return String(s).replace(/%/g,"%%"); }

/* ---------- run a batch, blocking / async (family) ---------- */
function runBat(lines, show){
  var fso=new ActiveXObject("Scripting.FileSystemObject"), sh=new ActiveXObject("WScript.Shell");
  var tmp=fso.GetSpecialFolder(2)+"", stamp=uid(), bat=tmp+"\\vsb_"+stamp+".bat", logp=tmp+"\\vsb_"+stamp+".log";
  var f=fso.CreateTextFile(bat,true); f.WriteLine("@echo off");
  for(var i=0;i<lines.length;i++){ f.WriteLine(lines[i].replace(/__LOG__/g,logp)); } f.Close();
  var rc=sh.Run('cmd /c ""'+bat+'""', show?1:0, true);
  var txt=""; try{ if(fso.FileExists(logp)) txt=readUtf8(logp); }catch(e){ txt="(could not read log: "+e.message+")"; }
  try{ fso.DeleteFile(bat); }catch(e2){} try{ if(fso.FileExists(logp)) fso.DeleteFile(logp); }catch(e3){}
  return { rc:rc, log:txt };
}
function runBatAsync(lines, show){
  var fso=new ActiveXObject("Scripting.FileSystemObject"), sh=new ActiveXObject("WScript.Shell");
  var tmp=fso.GetSpecialFolder(2)+"", stamp=uid();
  var bat=tmp+"\\vsb_"+stamp+".bat", logp=tmp+"\\vsb_"+stamp+".log", donep=tmp+"\\vsb_"+stamp+".done";
  var f=fso.CreateTextFile(bat,true); f.WriteLine("@echo off");
  for(var i=0;i<lines.length;i++){ f.WriteLine(lines[i].replace(/__LOG__/g,logp)); }
  f.WriteLine('echo done> "'+donep+'"'); f.Close();
  sh.Run('cmd /c ""'+bat+'""', show?1:0, false);
  return { bat:bat, log:logp, done:donep, elapsed:0 };
}
function pollDone(ctx){
  var fso=new ActiveXObject("Scripting.FileSystemObject");
  if(fso.FileExists(ctx.done)){
    var log=""; try{ if(fso.FileExists(ctx.log)) log=readUtf8(ctx.log); }catch(e){ log="(could not read log: "+e.message+")"; }
    try{ fso.DeleteFile(ctx.bat); }catch(e1){} try{ fso.DeleteFile(ctx.done); }catch(e2){}
    try{ if(fso.FileExists(ctx.log)) fso.DeleteFile(ctx.log); }catch(e3){}
    ctx.onDone(log); return;
  }
  ctx.elapsed+=1;
  if(ctx.elapsed>2400){ ctx.onTimeout&&ctx.onTimeout(); return; }   // 40-min cap (huge tars)
  if(ctx.onTick) ctx.onTick(ctx.elapsed);
  window.setTimeout(function(){ pollDone(ctx); }, 1000);
}
/* terminate the batch a runBatAsync launched AND its children (tar.exe). A timeout that merely stops
   polling leaves a full-archive tar pass running while BUSY drops to false - the abandoned process
   then races the next run for the same output files. WMI match is on the unique per-run .bat path. */
function killBatTree(ctx){
  var killed=0;
  try{
    var svc=GetObject("winmgmts:{impersonationLevel=impersonate}!\\\\.\\root\\cimv2");
    var like=String(ctx.bat).replace(/\\/g,"\\\\").replace(/'/g,"_").replace(/%/g,"_");
    var procs=svc.ExecQuery("SELECT ProcessId FROM Win32_Process WHERE CommandLine LIKE '%"+like+"%'");
    var e=new Enumerator(procs);
    for(; !e.atEnd(); e.moveNext()){ var p=e.item(), pid=p.ProcessId;
      try{ var kids=new Enumerator(svc.ExecQuery("SELECT * FROM Win32_Process WHERE ParentProcessId="+pid));
        for(; !kids.atEnd(); kids.moveNext()){ try{ kids.item().Terminate(); killed++; }catch(ek){} } }catch(e2){}
      try{ p.Terminate(); killed++; }catch(et){} }
  }catch(e){}
  try{ var fso=new ActiveXObject("Scripting.FileSystemObject");
    try{ fso.DeleteFile(ctx.bat); }catch(c1){} try{ fso.DeleteFile(ctx.done); }catch(c2){} try{ fso.DeleteFile(ctx.log); }catch(c3){}
  }catch(e4){}
  return killed;
}

/* ---------- fs helpers (family) ---------- */
function fileExists(p){ try{ return new ActiveXObject("Scripting.FileSystemObject").FileExists(p); }catch(e){ return false; } }
function fileSize(p){ try{ return new ActiveXObject("Scripting.FileSystemObject").GetFile(p).Size; }catch(e){ return -1; } }
function folderExists(p){ try{ return new ActiveXObject("Scripting.FileSystemObject").FolderExists(p); }catch(e){ return false; } }
function parentDir(p){ var i=String(p).lastIndexOf("\\"); return i>=0?p.substring(0,i):p; }
function ensureDir(p){ try{ var fso=new ActiveXObject("Scripting.FileSystemObject");
  if(!p || fso.FolderExists(p)) return fso.FolderExists(p);
  var parent=parentDir(p); if(parent && parent!==p && !fso.FolderExists(parent)) ensureDir(parent);
  fso.CreateFolder(p); return true; }catch(e){ return false; } }
function htaFolder(){
  try{ var cl=vsHta.commandLine+""; var m=cl.match(/"([^"]+\.hta)"/i); if(!m) m=cl.match(/([A-Za-z]:\\[^"]+\.hta)/i);
    if(m) return parentDir(m[1]); }catch(e){}
  try{ var p=decodeURIComponent(location.pathname+"").replace(/^\//,"").replace(/\//g,"\\"); return parentDir(p); }catch(e2){}
  return "";
}
function fileMtime(p){ try{ return String(new ActiveXObject("Scripting.FileSystemObject").GetFile(p).DateLastModified); }catch(e){ return ""; } }
function deleteTree(p){ try{ var fso=new ActiveXObject("Scripting.FileSystemObject"); if(fso.FolderExists(p)) fso.DeleteFolder(p,true); return true; }catch(e){ return false; } }

/* ---------- source-cache binding (v1.15.0) ----------
   _extracted / _view / _nodecfg / toc.tsv are keyed by OUTPUT FOLDER (i.e. by hostname). Before this,
   any file already on disk was reused purely because it existed - so a second, different capture from
   the same hostname (or a same-short-name host in another domain) silently consumed the FIRST capture's
   files. source.json binds the cache to the source identity (canonical path + size + last-write); a
   mismatch wipes the derived caches before anything can read them. Fingerprint is identity-grade, not
   content-grade (no full SHA-256 of a multi-GB archive per run) - size+mtime changes on any re-capture. */
function sourceSigOf(src, mode){
  var sz=-1, mt="";
  try{ if(mode!=="tree" && fileExists(src)){ sz=fileSize(src); mt=fileMtime(src); }
       else if(mode==="tree"){ var rd=src+"\\README"; if(fileExists(rd)){ sz=fileSize(rd); mt=fileMtime(rd); } } }catch(e){}
  return { src:lc(String(src||"")), size:sz, mtime:mt, mode:String(mode||"") };
}
function sourceManifestPath(outdir){ return String(outdir).replace(/[\\\/]+$/,"")+"\\source.json"; }
function bindSourceCache(outdir, src, mode){
  try{
    var sig=sourceSigOf(src, mode), p=sourceManifestPath(outdir), old=null;
    try{ if(fileExists(p)) old=JSON.parse(readUtf8(p)); }catch(e0){}
    if(old && old.src===sig.src && old.size===sig.size && old.mtime===sig.mtime && old.mode===sig.mode) return true;   // same source - caches valid
    if(old){
      appendLog("SOURCE CHANGED for this output folder - cached extractions belong to a different capture and are being discarded:\n  cached: "+old.src+" | "+old.size+" | "+old.mtime+"\n  current: "+sig.src+" | "+sig.size+" | "+sig.mtime);
      var od=String(outdir).replace(/[\\\/]+$/,"");
      deleteTree(od+"\\_extracted"); deleteTree(od+"\\_view"); deleteTree(od+"\\_nodecfg"); deleteTree(od+"\\_inner");
      try{ var fso=new ActiveXObject("Scripting.FileSystemObject");
        if(fso.FileExists(od+"\\toc.tsv")) fso.DeleteFile(od+"\\toc.tsv");
        if(fso.FileExists(od+"\\inner.json")) fso.DeleteFile(od+"\\inner.json"); }catch(e1){}
    }
    writeUtf8(p, JSON.stringify(sig,null,1));
    return !old;
  }catch(e){ appendLog("source-cache binding failed ("+e.message+") - caches NOT validated this run."); return false; }
}

/* ---------- tar.exe (extraction engine) ---------- */
function resolveTar(){
  var cands=["C:\\Windows\\System32\\tar.exe","C:\\Windows\\Sysnative\\tar.exe","tar.exe"];
  for(var i=0;i<cands.length;i++){ if(cands[i].indexOf("\\")<0 || fileExists(cands[i])){ TAR=cands[i]; return true; } }
  TAR=""; return false;
}
function checkTar(){
  var p=$("verpill");
  if(!TAR){ p.className="pill bad"; p.innerHTML="bsdtar: not found"; p.title="C:\\Windows\\System32\\tar.exe is missing (needs Windows 10 1803+). Extraction will not work."; p.onclick=function(){ openUrl("https://learn.microsoft.com/windows-server/administration/windows-commands/tar"); }; return; }
  try{ var r=runBat(['"'+batEsc(TAR)+'" --version > "__LOG__" 2>&1']);
    var m=r.log.match(/bsdtar\s+([0-9.]+)/i); TAR_VER=m?m[1]:"";
    p.className="pill ok"; p.innerHTML = TAR_VER ? ("bsdtar v"+esc(TAR_VER)) : "bsdtar present"; p.title="Extraction engine present and working: "+TAR;
    $("exeline").innerHTML="Extractor: "+esc(TAR)+(TAR_VER?(" (bsdtar "+esc(TAR_VER)+")"):"");
  }catch(e){ p.className="pill bad"; p.innerHTML="bsdtar: error"; }
}

/* ---------- zstd.exe (probe -> prompted download of official facebook/zstd build) ---------- */
function toolsDir(){ var d=htaFolder(); return d?(d+"\\tools"):""; }
function resolveZstd(){
  var cand=[]; var td=toolsDir(); if(td) cand.push(td+"\\zstd.exe");
  for(var i=0;i<cand.length;i++){ if(fileExists(cand[i])){ ZSTD=cand[i]; return true; } }
  try{ var r=runBat(['where zstd > "__LOG__" 2>&1']); var m=(r.log+"").match(/^[A-Za-z]:\\.*zstd\.exe/mi); if(m){ ZSTD=trimStr(m[0]); return true; } }catch(e){}
  ZSTD=""; return false;
}
function checkZstd(){
  var p=$("zstdpill");
  if(ZSTD){ p.innerHTML="zstd: <span class='ok'>ready</span>"; p.title="zstd.exe found - vCenter .zst logs will decompress."; }
  else { p.innerHTML="zstd: <span class='muted'>not needed</span>"; p.title="Not a problem. zstd.exe is ONLY needed for vCenter (VCSA) .zst logs; ESXi bundles use .gz which is handled natively. If a .zst log is actually encountered, the tool offers to fetch the official zstd.exe on demand - nothing to do until then."; }
}
function ensureZstd(){
  if(ZSTD) return true;
  if(resolveZstd()){ checkZstd(); return true; }
  if(!NET_ON){ setStatus("A .zst log needs zstd.exe, which is not installed - and offline mode blocks the download. Place zstd.exe in tools\\ next to the app, or tick the 'online' checkbox.","err"); return false; }
  var url="https://github.com/facebook/zstd/releases/latest";
  if(!confirm("This file is zstd-compressed (.zst) and needs zstd.exe, which is not installed.\n\nDownload the official Windows build from the facebook/zstd GitHub release and cache it in tools\\ next to this app?\n\nSource: "+url)) return false;
  var td=toolsDir(); if(!td){ setStatus("Can't locate the app folder to cache zstd.exe.","err"); return false; }
  ensureDir(td);
  setStatus("Downloading zstd.exe from GitHub…","muted"); appendLog("Fetching latest facebook/zstd win64 release → "+td+"\\zstd.exe");
  var fso=new ActiveXObject("Scripting.FileSystemObject"), tmp=fso.GetSpecialFolder(2)+"", ps1=tmp+"\\zstdget_"+uid()+".ps1";
  var tdq=td.replace(/'/g,"''");
  var L=[
    "$ErrorActionPreference='Stop'",
    "[Net.ServicePointManager]::SecurityProtocol=[Net.SecurityProtocolType]::Tls12",
    "$h=@{ 'User-Agent'='vSphere-SupportBundle-Analyzer' }",
    "$rel=Invoke-RestMethod -Uri 'https://api.github.com/repos/facebook/zstd/releases/latest' -Headers $h",
    "$a=$rel.assets | Where-Object { $_.name -match 'win64.*\\.zip$' } | Select-Object -First 1",
    "if(-not $a){ throw 'no win64 zip asset found in latest release' }",
    "$zip=Join-Path $env:TEMP ('zstd_'+[guid]::NewGuid().ToString('N')+'.zip')",
    "Invoke-WebRequest -Uri $a.browser_download_url -OutFile $zip -Headers $h",
    "$ex=Join-Path $env:TEMP ('zstd_'+[guid]::NewGuid().ToString('N'))",
    "Expand-Archive -Path $zip -DestinationPath $ex -Force",
    "$exe=Get-ChildItem -Path $ex -Recurse -Filter 'zstd.exe' | Select-Object -First 1",
    "if(-not $exe){ throw 'zstd.exe not found inside the downloaded zip' }",
    "Copy-Item $exe.FullName (Join-Path '"+tdq+"' 'zstd.exe') -Force",
    "Remove-Item $zip,$ex -Recurse -Force -ErrorAction SilentlyContinue",
    "Write-Output 'ZSTD_OK'"
  ];
  try{ var f=fso.CreateTextFile(ps1,true); f.Write(L.join("\r\n")); f.Close(); }catch(ew){ setStatus("zstd download stage failed: "+ew.message,"err"); return false; }
  var r=runBat(['powershell -NoProfile -ExecutionPolicy Bypass -File "'+ps1+'" > "__LOG__" 2>&1'], false);
  try{ fso.DeleteFile(ps1); }catch(e0){}
  if((r.log+"").indexOf("ZSTD_OK")>=0 && resolveZstd()){ checkZstd(); setStatus("zstd.exe installed in tools\\.","ok"); return true; }
  appendLog("--- zstd download ---\n"+r.log); setStatus("Could not install zstd.exe - see log. Install it manually into tools\\.","err"); return false;
}

/* ---------- target hostname + _Processed convention (family) ---------- */
var HOST_TOUCHED=false, OUT_TOUCHED=false;
function sanitHost(s){ return String(s).replace(/[^A-Za-z0-9._\-]/g,"-").replace(/^[\-.]+|[\-.]+$/g,""); }
/* ESXi: esx-<something>-<host>-<date>--<time>-<num>  |  VCSA: <host>-vcsa-... or vc-<host>-<date>...
   Bundle folder / archive name carries the host - peel the timestamp tail. */
function guessHost(p){
  p=String(p||""); var b=baseName(p).replace(/\.(tar\.gz|tgz|tar|zip)$/i,"");
  // esx-<prefix>-<fqdn>-YYYY-MM-DD--HH.MM-<digits>
  var me=b.match(/^esx-[^-]+-(.+?)-\d{4}-\d{2}-\d{2}--/i); if(me) return me[1];
  // vc-<fqdn>-YYYY-MM-DD--HH.MM-<digits>
  var mv=b.match(/^vc-(.+?)-\d{4}-\d{2}-\d{2}--/i); if(mv) return mv[1];
  // <name>-vcsa-support-log-bundle-XXXX
  var mb=b.match(/^(.+?)-vcsa-support-log-bundle/i); if(mb) return mb[1];
  var mp=p.match(/[\\\/]_Processed[\\\/]([^\\\/]+)[\\\/]/i); if(mp) return mp[1];
  return "";
}
function defaultOutDir(){
  var h=sanitHost($("hostName").value); if(!h) return "";
  var base=htaFolder(); if(!base){ try{ base=new ActiveXObject("Scripting.FileSystemObject").GetSpecialFolder(2)+""; }catch(e){ return ""; } }
  return base+"\\_Processed\\"+h+"\\"+APP_NAME;
}
function syncOutDir(){ if(OUT_TOUCHED) return; var d=defaultOutDir(); if(d) $("outDir").value=d; }
function hostGuessFrom(p){ if(!HOST_TOUCHED || !trimStr($("hostName").value)){ var g=guessHost(p); if(g) $("hostName").value=sanitHost(g); } syncOutDir(); }
function requireHost(){
  var h=sanitHost($("hostName").value);
  if(!h){ setStatus("Target hostname is required - it names the output folder _Processed\\<host>\\"+APP_NAME+". Type the host this bundle came from, then Analyze again.","err");
    try{ $("hostName").focus(); }catch(e){} return ""; }
  if(!trimStr($("outDir").value)) syncOutDir();
  return h;
}

/* ---------- run provenance (family) ---------- */
var RUNINFO_LAST=null;
function nowStamp(){ var d=new Date(); function p(x){return (x<10?"0":"")+x;}
  return d.getFullYear()+""+p(d.getMonth()+1)+p(d.getDate())+"_"+p(d.getHours())+p(d.getMinutes())+p(d.getSeconds()); }
/* SHA-256 of this .hta via certutil - computed once, recorded in every runinfo entry so a report can
   be tied to the exact tool build that produced it. */
function selfSha256(){
  if(SELF_SHA!==null) return SELF_SHA;
  SELF_SHA="";
  try{ var p=selfPath(); if(p && fileExists(p)){
    var r=runBat(['certutil -hashfile "'+batEsc(p)+'" SHA256 > "__LOG__" 2>&1'], false);
    var m=(r.log+"").replace(/[\s\r\n]/g,"").match(/SHA256.*?([0-9a-fA-F]{64})/);
    if(m) SELF_SHA=lc(m[1]); } }catch(e){}
  return SELF_SHA;
}
function writeRunInfo(outdir, input){
  try{
    var p=String(outdir).replace(/[\\\/]+$/,"")+"\\runinfo.json"; var arr=[];
    try{ if(fileExists(p)){ var old=JSON.parse(readUtf8(p)); if(old && old.length!=null) arr=old; } }catch(e0){}
    var iso=isoNowUtc();
    /* keyFilesPresent used to count the WHOLE inventory, not the key=true entries - misnamed evidence
       in a report. Both figures are now recorded under honest names. */
    var present=0, kp=0, kt=0;
    for(var i=0;i<INVENTORY.length;i++){ var it=INVENTORY[i];
      if(it.present) present++;
      if(it.key){ kt++; if(it.present) kp++; } }
    var srcArch=(MODE==="toc")?ARCHIVE:"";
    var ent={ app:APP_NAME, appVersion:APP_VERSION, appSha256:selfSha256(),
              host:sanitHost($("hostName").value), parsedFqdn:(NODE&&NODE.host)||"",
              bundleType:(BTYPE==="esxi"?"ESXi":(BTYPE==="vcsa"?"vCenter (VCSA)":"unknown")),
              input:String(input||""), archive:srcArch,
              source:sourceSigOf((MODE==="tree")?ROOT:(srcArch||input), MODE),
              mode:MODE, finishedUtc:iso,
              extractor:TAR, bsdtarVersion:TAR_VER, zstd:ZSTD||"",
              filesPresent:present, filesTotal:INVENTORY.length,
              keyFilesPresent:kp, keyFilesTotal:kt,
              tocMembers:TOC.length, tocRejected:TOC_BAD, tocCollisions:TOC_CLASH,
              node:NODE };
    arr.push(ent);
    writeUtf8(p, JSON.stringify(arr,null,2)); RUNINFO_LAST={path:p, iso:iso};
    writeUtf8(String(outdir).replace(/[\\\/]+$/,"")+"\\inventory.json", JSON.stringify(INVENTORY,null,2));
  }catch(e){ appendLog("runinfo write failed: "+e.message); }
}
/* amend the just-written runinfo entry with what only exists AFTER analysis: truncation disclosures,
   parser failures, vpxd coverage. Provenance that omits its own gaps is not provenance. */
function amendRunInfo(){
  try{
    if(!RUNINFO_LAST || !RUNINFO_LAST.path || !fileExists(RUNINFO_LAST.path)) return;
    var arr=JSON.parse(readUtf8(RUNINFO_LAST.path)); if(!arr || !arr.length) return;
    var ent=null; for(var i=arr.length-1;i>=0;i--){ if(arr[i].finishedUtc===RUNINFO_LAST.iso){ ent=arr[i]; break; } }
    if(!ent) return;
    ent.analysisFinishedUtc=isoNowUtc();
    ent.logsTruncated=LOG_TRUNC.slice(0);
    ent.parserFailures=ANALYSIS_ERRS.slice(0);
    ent.vpxdSet=VPXD_SRCNOTE||"";
    writeUtf8(RUNINFO_LAST.path, JSON.stringify(arr,null,2));
  }catch(e){ appendLog("runinfo amend failed: "+e.message); }
}

/* ============================================================
   CATALOGS - curated high-value files per bundle type (SPEC 5)
   entry: {cat, name, desc, rels:[...], dir:bool, key:bool}
   rels are paths RELATIVE to the bundle root (the <host> folder).
   dir=true -> rels are directory prefixes (size=sum, count=#files).
   ============================================================ */
var CAT_ESXI=[
  {cat:"Config", key:false, name:"README", desc:"Bundle manifest - capture time, vm-support version, command line.", rels:["README"]},
  {cat:"Config", key:true,  name:"esx.conf", desc:"Primary host config: networking, storage, auth references.", rels:["etc/vmware/esx.conf"]},
  {cat:"Config", key:false, name:"config", desc:"Global VMware config (advanced settings).", rels:["etc/vmware/config"]},
  {cat:"Config", key:false, name:"DCUI welcome banner", desc:"Direct Console welcome text - tamper / branding check.", rels:["etc/vmware/welcome"]},
  {cat:"Config", key:false, name:"firewall service.xml", desc:"ESXi firewall service definitions.", rels:["etc/vmware/firewall/service.xml"]},
  {cat:"Config", key:false, name:"AD/Kerberos join", desc:"Likewise AD/Kerberos join config (domain membership).", rels:["etc/likewise/likewise-krb5-ad.conf"]},
  {cat:"Config", key:false, name:"local accounts / groups", desc:"Local users & groups (vm-support usually excludes passwd/shadow; group is captured).", rels:["etc/passwd","etc/group"]},
