  {cat:"Persistence", key:true,  name:"VIB list", desc:"Installed VIBs - rogue / unsigned package check.", rels:["commands/localcli_software-vib-list.txt"]},
  {cat:"Persistence", key:true,  name:"VIB acceptance level", desc:"CommunitySupport acceptance = elevated risk.", rels:["commands/localcli_software-acceptance-get.txt"]},
  {cat:"Persistence", key:false, name:"rc.local.d/local.sh", desc:"Boot-time persistence script.", rels:["etc/rc.local.d/local.sh"]},
  {cat:"Command-capture", key:false, name:"version-get", desc:"Product / version / build / patch level.", rels:["commands/localcli_system-version-get.txt"]},
